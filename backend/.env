# The Grand Aurelia – Environment Configuration
# ─────────────────────────────────────────────────────────────────
# AI CONCIERGE SETUP
# ─────────────────────────────────────────────────────────────────
# Paste your OpenAI API key below.
# If left blank, the server automatically uses the built-in Mock
# Concierge (keyword-driven, no internet required — great for dev).
#
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model to use for the concierge.
# Options: gpt-3.5-turbo (cheaper), gpt-4o (smarter), gpt-4-turbo
OPENAI_MODEL=gpt-3.5-turbo

# ─────────────────────────────────────────────────────────────────
# FLASK SETTINGS
# ─────────────────────────────────────────────────────────────────
# Change this to a long random string in production!
SECRET_KEY=aurelia-dev-secret-change-in-prod
